<?xml version="1.0" encoding="utf-8"?>
<!--
    OpenTune launcher foreground.
    Stylized eighth note with the flag detached from the stem to suggest "open"/unlocked.
    Drawn over a 108x108 viewport; visible content stays inside the central 72x72 safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Note head -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 38,72
                          m -11,4
                          a 11,8 -20 1,0 22,-8
                          a 11,8 -20 1,0 -22,8 z"/>

    <!-- Note stem -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 49,68
                          L 49,32
                          L 53,32
                          L 53,68 Z"/>

    <!-- Detached flag — separated from stem, suggesting "open" -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 56,30
                          C 65,34 72,40 72,48
                          C 72,52 70,55 67,57
                          C 71,52 69,46 56,42 Z"/>

    <!-- Accent dot above the flag -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.85"
        android:pathData="M 75,28
                          m -3,0
                          a 3,3 0 1,0 6,0
                          a 3,3 0 1,0 -6,0 z"/>

</vector>
