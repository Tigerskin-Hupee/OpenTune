<?xml version="1.0" encoding="utf-8"?>
<!--
    OpenTune launcher foreground.
    Open ring (270° arc) merges with the note stem — the gap IS the connection point.
    Ring = "Open", ring + stem + flag = musical note.
    Safe zone: 18-90 on the 108x108 viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Open ring: center(50,68), radius=18, 270° clockwise arc        -->
    <!-- Start = top (50,50), End = right (68,68), gap at top-right     -->
    <path
        android:pathData="M50,50 A18,18 0 1,1 68,68"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="7"
        android:strokeLineCap="round"/>

    <!-- Stem: from ring's open end straight up -->
    <path
        android:pathData="M68,68 L68,26"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6.5"
        android:strokeLineCap="round"/>

    <!-- Flag: eighth-note flag curving from stem top -->
    <path
        android:pathData="M68,26 C82,30 86,46 74,58"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

</vector>
